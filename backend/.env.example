# Server
PORT=5000
NODE_ENV=development

# Comma-separated list of origins allowed to call this API
# e.g. http://localhost:5500,https://your-project.web.app
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# --- Firebase Admin SDK (backend) ---
# Generate this in Firebase Console > Project Settings > Service Accounts > Generate new private key
# Paste the FULL JSON contents on ONE line, or point to a file path instead (see firebase/admin.js).
FIREBASE_SERVICE_ACCOUNT_JSON=

# Optional: path to the service account key file instead of inline JSON
FIREBASE_SERVICE_ACCOUNT_PATH=

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com

# If no service account is configured, the server automatically falls back
# to a local JSON-file datastore (backend/data/courses.json) so the app
# remains fully functional in demo/dev mode.
