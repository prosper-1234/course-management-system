rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Courses collection: any authenticated user (including anonymous,
    // since this demo uses Firebase Anonymous Auth for one-click login)
    // may read and write. Tighten this for real production use, e.g. by
    // scoping documents to request.auth.uid.
    match /courses/{courseId} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
